      "source": [
        "## OGB Graph Classification: `ogbg-molhiv` \n",
        "\n",
        "This notebook compares standard GAT and GATv2 on OGB datasets **not used in the paper's core OGB table**.\n",
        "\n",
        "### Datasets in scope\n",
        "\n",
        "- `ogbg-molhiv` (binary graph classification, metric: ROC-AUC)\n",
        "\n",
        "### Usage\n",
        "\n",
        "1. Set `DATASET_NAME` in the config cell to either dataset.\n",
        "2. Run all cells.\n",
        "3. Compare validation/test curves and best test score at best validation epoch for GAT vs GATv2."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "id": "2d835b89",
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Device: cpu\n"
          ]
        }
      ],
      "source": [
        "import random\n",
        "import numpy as np\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "import torch.optim as optim\n",
        "import matplotlib.pyplot as plt\n",
        "import importlib.util\n",
        "import os\n",
        "\n",
        "from torch_geometric.loader import DataLoader\n",
        "import torch_geometric.data.data as pyg_data_data\n",
        "import torch_geometric.data.storage as pyg_storage\n",
        "from ogb.graphproppred import PygGraphPropPredDataset, Evaluator\n",
        "\n",
        "\n",
        "def set_seed(seed=42):\n",
        "    random.seed(seed)\n",
        "    np.random.seed(seed)\n",
        "    torch.manual_seed(seed)\n",
        "    if torch.cuda.is_available():\n",
        "        torch.cuda.manual_seed_all(seed)\n",
        "\n",
        "\n",
        "set_seed(42)\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "print('Device:', device)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "d2fa49b8",
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Dataset: ogbg-molhiv\n",
            "Task type: binary classification\n",
            "Metric: rocauc\n",
            "Num graphs: 41127\n",
            "Num features: 9\n",
            "Num tasks: 1\n",
            "Num classes: 2\n",
            "Split sizes: 32901 4113 4113\n"
          ]
        }
      ],
      "source": [
        "# -------------------- Config --------------------\n",
        "DATASET_NAME = 'ogbg-molhiv'
        "BATCH_SIZE = 128\n",
        "WEIGHT_DECAY = 0.0\n",
        "\n",
        "# GAT baseline config\n",
        "GAT_EPOCHS = 30\n",
        "GAT_HIDDEN_DIM = 128\n",
        "GAT_NUM_LAYERS = 3\n",
        "GAT_HEADS = 4\n",
        "GAT_DROPOUT = 0.2\n",
        "GAT_LR = 1e-3\n",
        "GAT_PATIENCE = 20\n",
        "\n",
        "# GATv2 tuned config\n",
        "GATV2_EPOCHS = 30\n",
        "GATV2_HIDDEN_DIM = 192\n",
        "GATV2_NUM_LAYERS = 4\n",
        "GATV2_HEADS = 4\n",
        "GATV2_DROPOUT = 0.1\n",
        "GATV2_LR = 5e-4\n",
        "GATV2_PATIENCE = 20\n",
        "GATV2_USE_RESIDUAL = True\n",
        "GATV2_USE_LAYER_NORM = True\n",
        "\n",
        "# -------------------- Data --------------------\n",
        "# PyTorch 2.6+ defaults torch.load(..., weights_only=True). OGB's preprocessed\n",
        "# PyG objects require allowlisting graph classes for safe deserialization.\n",
        "_safe_names = [\n",
        "    'Data', 'DataEdgeAttr', 'DataTensorAttr',\n",
        "    'BaseStorage', 'NodeStorage', 'EdgeStorage', 'GlobalStorage'\n",
        "]\n",
        "_safe_objs = []\n",
        "for name in _safe_names:\n",
        "    obj = getattr(pyg_data_data, name, None)\n",
        "    if obj is None:\n",
        "        obj = getattr(pyg_storage, name, None)\n",
        "    if obj is not None:\n",
        "        _safe_objs.append(obj)\n",
        "if _safe_objs:\n",
        "    torch.serialization.add_safe_globals(_safe_objs)\n",
        "\n",
        "dataset = PygGraphPropPredDataset(name=DATASET_NAME)\n",
        "split_idx = dataset.get_idx_split()\n",
        "\n",
        "train_loader = DataLoader(dataset[split_idx['train']], batch_size=BATCH_SIZE, shuffle=True)\n",
        "valid_loader = DataLoader(dataset[split_idx['valid']], batch_size=BATCH_SIZE, shuffle=False)\n",
        "test_loader = DataLoader(dataset[split_idx['test']], batch_size=BATCH_SIZE, shuffle=False)\n",
        "\n",
        "evaluator = Evaluator(name=DATASET_NAME)\n",
        "task_type = dataset.task_type\n",
        "num_tasks = dataset.num_tasks\n",
        "num_classes = dataset.num_classes\n",
        "\n",
        "print('Dataset:', DATASET_NAME)\n",
        "print('Task type:', task_type)\n",
        "print('Metric:', evaluator.eval_metric)\n",
        "print('Num graphs:', len(dataset))\n",
        "print('Num features:', dataset.num_features)\n",
        "print('Num tasks:', num_tasks)\n",
        "print('Num classes:', num_classes)\n",
        "print('Split sizes:', len(split_idx['train']), len(split_idx['valid']), len(split_idx['test']))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 10,
      "id": "f92ecf2d",
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Initialized OGB_GAT_Model and tuned OGB_GATv2_Model from src/models.py.\n"
          ]
        }
      ],
      "source": [
        "# Load OGB model implementations from src/models.py\n",
        "path_to_models = os.path.abspath(os.path.join('..', 'src', 'models.py'))\n",
        "spec = importlib.util.spec_from_file_location('models_direct', path_to_models)\n",
        "models_module = importlib.util.module_from_spec(spec)\n",
        "spec.loader.exec_module(models_module)\n",
        "\n",
        "OGB_GAT_Model = models_module.OGB_GAT_Model\n",
        "OGB_GATv2_Model = models_module.OGB_GATv2_Model\n",
        "\n",
        "if task_type == 'multiclass classification':\n",
        "    out_dim = int(num_classes)\n",
        "else:\n",
        "    out_dim = int(num_tasks)\n",
        "\n",
        "model_gat = OGB_GAT_Model(\n",
        "    nfeat=dataset.num_features,\n",
        "    nhid=GAT_HIDDEN_DIM,\n",
        "    nclass=out_dim,\n",
        "    num_layers=GAT_NUM_LAYERS,\n",
        "    nheads=GAT_HEADS,\n",
        "    dropout=GAT_DROPOUT,\n",
        "    alpha=0.2,\n",
        ").to(device)\n",
        "\n",
        "model_v2 = OGB_GATv2_Model(\n",
        "    nfeat=dataset.num_features,\n",
        "    nhid=GATV2_HIDDEN_DIM,\n",
        "    nclass=out_dim,\n",
        "    num_layers=GATV2_NUM_LAYERS,\n",
        "    nheads=GATV2_HEADS,\n",
        "    dropout=GATV2_DROPOUT,\n",
        "    alpha=0.2,\n",
        "    use_residual=GATV2_USE_RESIDUAL,\n",
        "    use_layer_norm=GATV2_USE_LAYER_NORM,\n",
        ").to(device)\n",
        "\n",
        "print('Initialized OGB_GAT_Model and tuned OGB_GATv2_Model from src/models.py.')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 11,
      "id": "6ca9cb87",
      "metadata": {},
      "outputs": [],
      "source": [
        "def train_one_epoch(model, loader, optimizer):\n",
        "    model.train()\n",
        "    total_loss = 0.0\n",
        "    total_graphs = 0\n",
        "\n",
        "    for batch in loader:\n",
        "        batch = batch.to(device)\n",
        "        optimizer.zero_grad()\n",
        "\n",
        "        pred = model(batch.x, batch.edge_index, batch.batch)\n",
        "\n",
        "        if task_type == 'binary classification':\n",
        "            y = batch.y.view(-1, num_tasks).float()\n",
        "            is_labeled = y == y\n",
        "            loss = F.binary_cross_entropy_with_logits(pred[is_labeled], y[is_labeled])\n",
        "        elif task_type == 'multiclass classification':\n",
        "            y = batch.y.view(-1).long()\n",
        "            loss = F.cross_entropy(pred, y)\n",
        "        else:\n",
        "            raise ValueError(f'Unsupported task_type: {task_type}')\n",
        "\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "\n",
        "        total_loss += loss.item() * batch.num_graphs\n",
        "        total_graphs += batch.num_graphs\n",
        "\n",
        "    return total_loss / max(total_graphs, 1)\n",
        "\n",
        "\n",
        "@torch.no_grad()\n",
        "def evaluate(model, loader):\n",
        "    model.eval()\n",
        "    y_true_list = []\n",
        "    y_pred_list = []\n",
        "\n",
        "    for batch in loader:\n",
        "        batch = batch.to(device)\n",
        "        pred = model(batch.x, batch.edge_index, batch.batch)\n",
        "\n",
        "        if task_type == 'multiclass classification':\n",
        "            pred_out = pred.argmax(dim=-1, keepdim=True).cpu()\n",
        "            y_out = batch.y.view(-1, 1).cpu()\n",
        "        else:\n",
        "            pred_out = pred.cpu()\n",
        "            y_out = batch.y.view(-1, num_tasks).cpu()\n",
        "\n",
        "        y_true_list.append(y_out)\n",
        "        y_pred_list.append(pred_out)\n",
        "\n",
        "    y_true = torch.cat(y_true_list, dim=0).numpy()\n",
        "    y_pred = torch.cat(y_pred_list, dim=0).numpy()\n",
        "    return evaluator.eval({'y_true': y_true, 'y_pred': y_pred})[evaluator.eval_metric]\n",
        "\n",
        "\n",
        "def run_experiment(model, name, epochs, lr, patience):\n",
        "    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=WEIGHT_DECAY)\n",
        "\n",
        "    train_losses = []\n",
        "    valid_scores = []\n",
        "    test_scores = []\n",
        "\n",
        "    best_val = -float('inf')\n",
        "    best_test_at_val = -float('inf')\n",
        "    wait = 0\n",
        "\n",
        "    for epoch in range(1, epochs + 1):\n",
        "        loss = train_one_epoch(model, train_loader, optimizer)\n",
        "        val_score = evaluate(model, valid_loader)\n",
        "        test_score = evaluate(model, test_loader)\n",
        "\n",
        "        train_losses.append(loss)\n",
        "        valid_scores.append(val_score)\n",
        "        test_scores.append(test_score)\n",
        "\n",
        "        if val_score > best_val:\n",
        "            best_val = val_score\n",
        "            best_test_at_val = test_score\n",
        "            wait = 0\n",
        "        else:\n",
        "            wait += 1\n",
        "\n",
        "        if epoch % 5 == 0 or epoch == 1:\n",
        "            print(f\"{name} | Epoch {epoch:03d} | Loss: {loss:.4f} | Val {evaluator.eval_metric}: {val_score:.4f} | Test {evaluator.eval_metric}: {test_score:.4f}\")\n",
        "\n",
        "        if wait >= patience:\n",
        "            print(f\"{name} | Early stopping at epoch {epoch} (best val {evaluator.eval_metric}: {best_val:.4f})\")\n",
        "            break\n",
        "\n",
        "    return {\n",
        "        'train_losses': train_losses,\n",
        "        'valid_scores': valid_scores,\n",
        "        'test_scores': test_scores,\n",
        "        'best_val': best_val,\n",
        "        'best_test_at_val': best_test_at_val,\n",
        "    }"
      ]
    },
    {
