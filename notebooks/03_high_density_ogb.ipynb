            "GATv2 | Epoch 020 | Loss: 0.1445 | Val rocauc: 0.7155 | Test rocauc: 0.7016\n",
            "GATv2 | Epoch 025 | Loss: 0.1400 | Val rocauc: 0.7299 | Test rocauc: 0.7225\n",
            "GATv2 | Epoch 030 | Loss: 0.1385 | Val rocauc: 0.7424 | Test rocauc: 0.7375\n",
            "\n",
            "Final summary\n",
            "Metric: rocauc\n",
            "GAT    | best val: 0.7695 | test@best-val: 0.7222\n",
            "GATv2  | best val: 0.7597 | test@best-val: 0.7386\n"
          ]
        }
      ],
      "source": [
        "print('Running GAT baseline...')\n",
        "print(f\"  config: hidden={GAT_HIDDEN_DIM}, layers={GAT_NUM_LAYERS}, heads={GAT_HEADS}, dropout={GAT_DROPOUT}, lr={GAT_LR}, epochs={GAT_EPOCHS}, patience={GAT_PATIENCE}\")\n",
        "res_gat = run_experiment(model_gat, 'GAT', epochs=GAT_EPOCHS, lr=GAT_LR, patience=GAT_PATIENCE)\n",
        "\n",
        "print('\\nRunning GATv2 (tuned)...')\n",
        "print(f\"  config: hidden={GATV2_HIDDEN_DIM}, layers={GATV2_NUM_LAYERS}, heads={GATV2_HEADS}, dropout={GATV2_DROPOUT}, lr={GATV2_LR}, epochs={GATV2_EPOCHS}, patience={GATV2_PATIENCE}, residual={GATV2_USE_RESIDUAL}, layer_norm={GATV2_USE_LAYER_NORM}\")\n",
        "res_v2 = run_experiment(model_v2, 'GATv2', epochs=GATV2_EPOCHS, lr=GATV2_LR, patience=GATV2_PATIENCE)\n",
        "\n",
        "print('\\nFinal summary')\n",
        "print(f\"Metric: {evaluator.eval_metric}\")\n",
        "print(f\"GAT    | best val: {res_gat['best_val']:.4f} | test@best-val: {res_gat['best_test_at_val']:.4f}\")\n",
        "print(f\"GATv2  | best val: {res_v2['best_val']:.4f} | test@best-val: {res_v2['best_test_at_val']:.4f}\")"
      ]
    },
